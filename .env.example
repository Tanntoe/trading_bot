# Copy this file to .env and fill in your real Alpaca credentials.
# NEVER commit your actual .env file to version control.

# Paper trading keys by default. Get them from https://app.alpaca.markets/paper/dashboard
ALPACA_API_KEY=your_alpaca_api_key_id
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Paper trading endpoint. Switch to https://api.alpaca.markets only when you
# intend to trade with real money and know what you are doing.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional overrides
POLL_INTERVAL_SECONDS=60
LOG_DIR=.
